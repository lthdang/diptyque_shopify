{%- capture ma_content -%}
<div
  id="my-account-app"
  data-storefront-endpoint="https://{{ shop.permanent_domain }}/api/2026-04/graphql.json"
  data-storefront-token="{{ settings.storefront_access_token }}"
  data-shop-id="{{ shop.id }}"
  data-logout-url="{{ routes.account_logout_url }}"
  data-t-nav-profile="{{ 'custom_account.nav_profile' | t }}"
  data-t-nav-orders="{{ 'custom_account.nav_orders' | t }}"
  data-t-nav-addresses="{{ 'custom_account.nav_addresses' | t }}"
  data-t-nav-cards="{{ 'custom_account.nav_cards' | t }}"
  data-t-nav-shipping="{{ 'custom_account.shipping' | t }}"
  data-t-profile-title="{{ 'custom_account.profile_title' | t }}"
  data-t-last-name="{{ 'custom_account.last_name' | t }}"
  data-t-first-name="{{ 'custom_account.first_name' | t }}"
  data-t-furigana-last="{{ 'custom_account.furigana_last' | t }}"
  data-t-furigana-first="{{ 'custom_account.furigana_first' | t }}"
  data-t-dob="{{ 'custom_account.dob' | t }}"
  data-t-phone="{{ 'custom_account.phone' | t }}"
  data-t-email="{{ 'custom_account.email' | t }}"
  data-t-required="{{ 'custom_account.required' | t }}"
  data-t-submit="{{ 'custom_account.submit' | t }}"
  data-t-login-info-title="{{ 'custom_account.login_info_title' | t }}"
  data-t-password="{{ 'custom_account.password' | t }}"
  data-t-new-password="{{ 'custom_account.new_password' | t }}"
  data-t-password-hint="{{ 'custom_account.password_hint' | t }}"
  data-t-password-confirm="{{ 'custom_account.password_confirm' | t }}"
  data-t-benefits-title="{{ 'custom_account.benefits_title' | t }}"
  data-t-benefits-subtitle="{{ 'custom_account.benefits_subtitle' | t }}"
  data-t-benefit-1="{{ 'custom_account.benefit_1' | t }}"
  data-t-benefit-2="{{ 'custom_account.benefit_2' | t }}"
  data-t-benefit-3="{{ 'custom_account.benefit_3' | t }}"
  data-t-logout="{{ 'custom_account.logout' | t }}"
  data-t-save-success="{{ 'custom_account.save_success' | t }}"
  data-t-save-failed="{{ 'custom_account.save_failed' | t }}"
  data-t-validation-required="{{ 'custom_account.validation_required' | t }}"
  data-t-validation-email-invalid="{{ 'custom_account.validation_email_invalid' | t }}"
  data-t-validation-phone-invalid="{{ 'custom_account.validation_phone_invalid' | t }}"
  data-t-validation-dob-invalid="{{ 'custom_account.validation_dob_invalid' | t }}"
  data-t-validation-password-weak="{{ 'custom_account.validation_password_weak' | t }}"
  data-t-validation-password-mismatch="{{ 'custom_account.validation_password_mismatch' | t }}"
  data-t-validation-password-required-all="{{ 'custom_account.validation_password_required_all' | t }}"
  data-t-update-not-supported="{{ 'custom_account.update_not_supported' | t }}"
  data-t-saving="{{ 'custom_account.saving' | t }}"
  data-api-base="{{ settings.be_api_base_url }}"
></div>
{%- endcapture -%}
{%- render 'my-account-layout', active_nav: 'profile', content: ma_content -%}

{% comment %} Hidden form used only to expose the CSRF token for native session AJAX updates {% endcomment %}
{% form 'customer', id: 'ma-native-form' %}{% endform %}

<script id="my-account-translations" type="application/json">
  {{ shop.metafields.translations.custom_account | json }}
</script>

{% if customer %}
<script id="my-account-native-customer" type="application/json">
  {
    "id": {{ customer.id | json }},
    "firstName": {{ customer.first_name | json }},
    "lastName": {{ customer.last_name | json }},
    "email": {{ customer.email | json }},
    "phone": {{ customer.phone | json }},
    "metafields": [
      {
        "namespace": "registration",
        "key": "first_name_kana",
        "value": {{ customer.metafields.registration.first_name_kana.value | json }},
        "type": {{ customer.metafields.registration.first_name_kana.type | json }}
      },
      {
        "namespace": "registration",
        "key": "last_name_kana",
        "value": {{ customer.metafields.registration.last_name_kana.value | json }},
        "type": {{ customer.metafields.registration.last_name_kana.type | json }}
      },
      {
        "namespace": "registration",
        "key": "birthday",
        "value": {{ customer.metafields.registration.birthday.value | json }},
        "type": {{ customer.metafields.registration.birthday.type | json }}
      }
    ],
    "defaultAddress": {% if customer.default_address %}{
      "id": {{ customer.default_address.id | json }},
      "firstName": {{ customer.default_address.first_name | json }},
      "lastName": {{ customer.default_address.last_name | json }},
      "address1": {{ customer.default_address.address1 | json }},
      "address2": {{ customer.default_address.address2 | json }},
      "city": {{ customer.default_address.city | json }},
      "province": {{ customer.default_address.province | json }},
      "zip": {{ customer.default_address.zip | json }},
      "country": {{ customer.default_address.country | json }},
      "phone": {{ customer.default_address.phone | json }}
    }{% else %}null{% endif %},
    "addresses": { "edges": [
      {% for address in customer.addresses %}
      { "node": {
        "id": {{ address.id | json }},
        "firstName": {{ address.first_name | json }},
        "lastName": {{ address.last_name | json }},
        "address1": {{ address.address1 | json }},
        "address2": {{ address.address2 | json }},
        "city": {{ address.city | json }},
        "province": {{ address.province | json }},
        "zip": {{ address.zip | json }},
        "country": {{ address.country | json }},
        "phone": {{ address.phone | json }}
      }}{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]},
    "orders": { "edges": [
      {% for order in customer.orders limit: 20 %}
      { "node": {
        "id": {{ order.id | json }},
        "name": {{ order.name | json }},
        "processedAt": {{ order.processed_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
        "financialStatus": {{ order.financial_status | upcase | json }},
        "fulfillmentStatus": {{ order.fulfillment_status | upcase | json }},
        "totalPrice": {
          "amount": {{ order.total_price | money_without_currency | remove: ',' | json }},
          "currencyCode": {{ order.currency | json }}
        },
        "lineItems": { "edges": [
          {% for item in order.line_items %}
          { "node": {
            "title": {{ item.title | json }},
            "quantity": {{ item.quantity }},
            "variant": {
              "title": {{ item.variant.title | json }},
              "image": {% if item.image %}{ "url": {{ item.image | img_url: '240x' | prepend: 'https:' | json }} }{% else %}null{% endif %},
              "price": {
                "amount": {{ item.price | money_without_currency | remove: ',' | json }},
                "currencyCode": {{ order.currency | json }}
              }
            }
          }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]}
      }}{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]}
  }
</script>
{% endif %}

<script src="{{ 'my-account.js' | asset_url }}" defer></script>

{% stylesheet %}
  /* ===== My Account — section-specific styles ===== */
  /* (Layout, sidebar, input, loading, benefits → my-account-layout.liquid snippet) */

  /* --- Profile Form --- */
  .my-account__form-section {
    margin-bottom: 40px;
  }

  .my-account__section-heading {
    font-size: 1.1rem;
    font-weight: 500;
    margin: 0 0 24px;
  }

  .my-account__form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .my-account__form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .my-account__form-field--full {
    grid-column: 1 / -1;
  }

  .my-account__form-field--hidden {
    display: none;
  }

  .my-account__form-field label {
    font-size: 0.75rem;
    color: #666;
  }

  /* --- Password Field --- */
  .my-account__password-input {
    position: relative;
    display: flex;
    align-items: center;
  }

  .my-account__password-input .my-account__input {
    padding-right: 48px;
  }

  .my-account__password-toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #888;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .my-account__password-toggle:hover {
    color: #000;
  }

  .my-account__submit-btn {
    width: 100%;
    padding: 14px;
    background: #b3b3b3;
    color: #fff;
    border: none;
    font-size: 0.85rem;
    cursor: pointer;
    text-align: center;
    transition: background 0.2s;
    margin-top: 16px;
    letter-spacing: 0.05em;
  }

  .my-account__submit-btn:hover {
    background: #000;
  }

  .my-account__password-hint {
    font-size: 0.7rem;
    color: #999;
    margin: 8px 0 0;
    line-height: 1.4;
  }

  .my-account__required-text {
    font-size: 0.75rem;
    color: #999;
    margin: 12px 0;
  }

  .my-account__submit-btn:disabled,
  .my-account__submit-btn--loading {
    background: #d0d0d0;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* --- Orders --- */
  .my-account__orders {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .my-account__order {
    border: 1px solid #e0e0e0;
    padding: 20px;
  }

  .my-account__order-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .my-account__order-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .my-account__order-name {
    font-size: 0.85rem;
    font-weight: 500;
  }

  .my-account__order-date {
    font-size: 0.75rem;
    color: #888;
  }

  .my-account__order-status {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .my-account__status-badge {
    font-size: 0.7rem;
    padding: 3px 8px;
    background: #f0f0f0;
    border-radius: 2px;
  }

  .my-account__status-badge--paid { background: #e6f4ea; color: #2a7a3b; }
  .my-account__status-badge--pending { background: #fef9e7; color: #8a6d00; }
  .my-account__status-badge--refunded { background: #fdecea; color: #c0392b; }
  .my-account__status-badge--fulfilled { background: #e8f0fe; color: #1a56c4; }
  .my-account__status-badge--unfulfilled { background: #f0f0f0; color: #555; }

  .my-account__order-items {
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-top: 1px solid #f0f0f0;
    padding-top: 12px;
  }

  .my-account__order-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .my-account__item-image {
    width: 64px;
    height: 64px;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid #f0f0f0;
  }

  .my-account__item-image--placeholder {
    background: #f5f5f5;
  }

  .my-account__item-details {
    flex: 1;
    min-width: 0;
  }

  .my-account__item-title {
    font-size: 0.8rem;
    font-weight: 500;
    margin: 0 0 4px;
  }

  .my-account__item-variant,
  .my-account__item-qty {
    font-size: 0.75rem;
    color: #888;
    margin: 0 0 2px;
  }

  .my-account__item-price {
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .my-account__order-total {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid #f0f0f0;
    padding-top: 12px;
    margin-top: 12px;
    font-size: 0.8rem;
  }

  .my-account__order-total-amount {
    font-weight: 600;
  }

  /* --- Addresses --- */
  .my-account__addresses {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .my-account__address-card {
    border: 1px solid #e0e0e0;
    padding: 16px;
    font-size: 0.8rem;
    line-height: 1.7;
    position: relative;
  }

  .my-account__address-card--default {
    border-color: #000;
  }

  .my-account__default-badge {
    display: inline-block;
    font-size: 0.68rem;
    background: #000;
    color: #fff;
    padding: 2px 8px;
    margin-bottom: 10px;
    letter-spacing: 0.04em;
  }

  .my-account__address-name {
    font-weight: 500;
    margin: 0 0 4px;
  }

  /* --- Empty State --- */
  .my-account__empty {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    padding: 20px 0;
  }

  .my-account__empty p {
    font-size: 0.85rem;
    color: #666;
    margin: 0;
  }

  .my-account__shop-btn {
    padding: 10px 24px;
    background: #000;
    color: #fff;
    font-size: 0.8rem;
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  /* --- Responsive --- */
  @media screen and (max-width: 749px) {
    .my-account__form-grid {
      grid-template-columns: 1fr;
    }

    .my-account__addresses {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Flatpickr theme overrides for my-account ---- */
  .flatpickr-calendar {
    font-family: inherit !important;
    border: 1px solid var(--color-border, #ccc) !important;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
    border-radius: 0 !important;
  }

  .flatpickr-calendar.open {
    z-index: 9999 !important;
  }

  .flatpickr-day.selected,
  .flatpickr-day.selected:hover {
    background: var(--color-foreground) !important;
    border-color: var(--color-foreground) !important;
    color: var(--color-background) !important;
  }

  .flatpickr-day:hover {
    background: rgba(0,0,0,0.06) !important;
  }

  .flatpickr-day.today {
    border-color: var(--color-foreground) !important;
  }

  .flatpickr-day.today:hover {
    background: rgba(0,0,0,0.06) !important;
    color: inherit !important;
  }

  .flatpickr-months .flatpickr-prev-month,
  .flatpickr-months .flatpickr-next-month {
    fill: var(--color-foreground) !important;
  }

  .flatpickr-current-month .numInputWrapper span.arrowUp:after {
    border-bottom-color: var(--color-foreground) !important;
  }

  .flatpickr-current-month .numInputWrapper span.arrowDown:after {
    border-top-color: var(--color-foreground) !important;
  }
{% endstylesheet %}

<link rel="stylesheet" href="{{ 'flatpickr.min.css' | asset_url }}">
<script src="{{ 'flatpickr.min.js' | asset_url }}" defer></script>
<script src="{{ 'flatpickr-l10n-ja.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "My Account",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
