
{% liquid
  assign heading_text = block.settings.heading_text | default: 'Collection Heading'
  assign heading_tag = block.settings.heading_tag | default: 'h2'
  assign alignment = block.settings.alignment | default: 'center'
  assign font_size = block.settings.font_size | default: 32
  assign letter_spacing = block.settings.letter_spacing | default: 0
  assign margin_bottom = block.settings.margin_bottom | default: 24
  assign show_divider = block.settings.show_divider | default: false
%}

<div
  class="collections-tabs-heading"
  style="
    text-align: {{ alignment }};
    margin-bottom: {{ margin_bottom }}px;
  "
  {{ block.shopify_attributes }}
>
  <{{ heading_tag }}
    class="collections-tabs-heading__text"
    style="
      font-size: {{ font_size }}px;
      letter-spacing: {{ letter_spacing }}em;
      margin: 0;
    "
  >
    {{ heading_text }}
  </{{ heading_tag }}>
  
  {% if show_divider %}
    <div
      class="collections-tabs-heading__divider"
      style="
        margin-top: {{ margin_bottom | divided_by: 2 }}px;
        width: 80px;
        height: 2px;
        background-color: currentColor;
        {% case alignment %}
          {% when 'center' %}
            margin-left: auto;
            margin-right: auto;
          {% when 'right' %}
            margin-left: auto;
          {% when 'left' %}
            margin-right: auto;
        {% endcase %}
      "
    ></div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Collection Tabs Heading",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Shop Collections"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": -0.1,
      "max": 0.3,
      "step": 0.1,
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider under heading",
      "default": false
    }
  ]
}
{% endschema %}
