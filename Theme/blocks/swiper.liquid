
{% liquid
  assign swiper_id = 'swiper-' | append: block.id

  if block.settings.aspect_ratio == 'custom'
    assign frame_style = '--swiper-frame-height: ' | append: block.settings.custom_height | append: 'px; --swiper-aspect-ratio: none;'
  else
    assign frame_style = '--swiper-aspect-ratio: ' | append: block.settings.aspect_ratio | append: '; --swiper-frame-height: auto;'
  endif

  if block.settings.width_type == 'custom'
    assign width_style = 'max-width: ' | append: block.settings.custom_width | append: 'px; margin-inline: auto;'
  else
    assign width_style = ''
  endif
%}

{% # theme-check-disable MissingAsset %}
{{- 'swiper-block.css' | asset_url | stylesheet_tag -}}
{% # theme-check-enable MissingAsset %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>

<div
  id="{{ swiper_id }}"
  class="swiper-block"
  style="
    --swiper-block-bg: {{ block.settings.bg_color }};
    --swiper-slide-bg: {{ block.settings.slide_bg_color }};
    --swiper-title-color: {{ block.settings.title_color }};
    --swiper-content-color: {{ block.settings.content_color }};
    {{ frame_style }}
    {{ width_style }}
  "
  data-slides-per-view="{{ block.settings.slides_per_view }}"
  data-space-between="{{ block.settings.slides_spacing }}"
  data-loop="{{ block.settings.loop_enabled }}"
  data-autoplay="{{ block.settings.autoplay_enabled }}"
  data-autoplay-delay="{{ block.settings.autoplay_delay }}"
  data-pause-on-hover="{{ block.settings.pause_on_hover }}"
  data-pagination="{{ block.settings.show_pagination }}"
  {{ block.shopify_attributes }}
>
  <!-- Swiper carousel container -->
  <div class="swiper-block__carousel swiper">
    <div class="swiper-wrapper">
      {% for i in (1..block.settings.slides_count) %}
        {%- assign slide_image          = 'slide_' | append: i | append: '_image'          | default: '' -%}
        {%- assign slide_title          = 'slide_' | append: i | append: '_title'          -%}
        {%- assign slide_content        = 'slide_' | append: i | append: '_content'        -%}
        {%- assign slide_link           = 'slide_' | append: i | append: '_link'           -%}
        {%- assign slide_label          = 'slide_' | append: i | append: '_link_label'     -%}
        {%- assign slide_img_width      = 'slide_' | append: i | append: '_image_width'    -%}
        {%- assign slide_img_h_mode     = 'slide_' | append: i | append: '_image_height_mode'   -%}
        {%- assign slide_img_h_fixed    = 'slide_' | append: i | append: '_image_fixed_height'  -%}
        {%- assign slide_img_pad_top    = 'slide_' | append: i | append: '_image_padding_top'    -%}
        {%- assign slide_img_pad_bot    = 'slide_' | append: i | append: '_image_padding_bottom' -%}
        {%- assign slide_img_pad_left   = 'slide_' | append: i | append: '_image_padding_left'   -%}
        {%- assign slide_img_pad_right  = 'slide_' | append: i | append: '_image_padding_right'  -%}
        {%- assign slide_img_align      = 'slide_' | append: i | append: '_image_alignment'      -%}
        {%- assign slide_img_fit        = 'slide_' | append: i | append: '_image_object_fit'     -%}
        {%- assign slide_img_pos        = 'slide_' | append: i | append: '_image_object_position' -%}
        {%- assign slide_img_radius     = 'slide_' | append: i | append: '_image_border_radius'  -%}
        {%- assign slide_text_align     = 'slide_' | append: i | append: '_text_alignment'        -%}
        {%- assign s_image          = block.settings[slide_image]        -%}
        {%- assign s_title          = block.settings[slide_title]        -%}
        {%- assign s_content        = block.settings[slide_content]      -%}
        {%- assign s_link           = block.settings[slide_link]         -%}
        {%- assign s_label          = block.settings[slide_label]        -%}
        {%- assign s_img_width      = block.settings[slide_img_width]    | default: 100 -%}
        {%- assign s_img_h_mode     = block.settings[slide_img_h_mode]   | default: 'aspect-ratio' -%}
        {%- assign s_img_h_fixed    = block.settings[slide_img_h_fixed]  | default: 300 -%}
        {%- assign s_img_pad_top    = block.settings[slide_img_pad_top]  | default: 0 -%}
        {%- assign s_img_pad_bot    = block.settings[slide_img_pad_bot]  | default: 0 -%}
        {%- assign s_img_pad_left   = block.settings[slide_img_pad_left] | default: 0 -%}
        {%- assign s_img_pad_right  = block.settings[slide_img_pad_right]| default: 0 -%}
        {%- assign s_img_align      = block.settings[slide_img_align]    | default: 'center' -%}
        {%- assign s_img_fit        = block.settings[slide_img_fit]      | default: 'cover' -%}
        {%- assign s_img_pos        = block.settings[slide_img_pos]      | default: 'center center' -%}
        {%- assign s_img_radius     = block.settings[slide_img_radius]   | default: 0 -%}
        {%- assign s_text_align     = block.settings[slide_text_align]   | default: 'left' -%}
        {%- liquid
          if s_img_h_mode == 'fixed'
            assign s_img_height = s_img_h_fixed | append: 'px'
          elsif s_img_h_mode == 'auto'
            assign s_img_height = 'auto'
          else
            assign s_img_height = '100%'
          endif
        -%}
        <div class="swiper-block__slide swiper-slide">

          {% if s_link != blank %}
            <a href="{{ s_link }}" class="swiper-block__slide-link">
          {% endif %}

          <!-- Slide image -->
          <div
            class="swiper-block__slide-media"
            style="
              --img-width: {{ s_img_width }}%;
              --img-height: {{ s_img_height }};
              --img-padding-top: {{ s_img_pad_top }}px;
              --img-padding-bottom: {{ s_img_pad_bot }}px;
              --img-padding-left: {{ s_img_pad_left }}px;
              --img-padding-right: {{ s_img_pad_right }}px;
              --img-alignment: {{ s_img_align }};
              --img-radius: {{ s_img_radius }}px;
            "
          >
            {%- assign s_img_style = 'object-fit: ' | append: s_img_fit | append: '; object-position: ' | append: s_img_pos | append: ';' -%}
            {% if s_image != blank %}
              {{
                s_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  class: 'swiper-block__slide-img',
                  alt: s_title,
                  widths: '400,600,900,1200',
                  sizes: '(max-width: 749px) 100vw, 50vw',
                  style: s_img_style
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'swiper-block__slide-placeholder' }}
            {% endif %}
          </div>

          <!-- Slide body -->
          {% if s_title != blank or s_content != blank or s_label != blank %}
            <div class="swiper-block__slide-body" style="text-align: {{ s_text_align }};">
              {% if s_title != blank %}
                <h3 class="swiper-block__slide-title">{{ s_title }}</h3>
              {% endif %}

              {% if s_content != blank %}
                <div class="swiper-block__slide-content rte">
                  {{ s_content }}
                </div>
              {% endif %}

              {% if s_link != blank and s_label != blank %}
                <span class="swiper-block__slide-cta">{{ s_label }}</span>
              {% endif %}
            </div>
          {% endif %}

          {% if s_link != blank %}
            </a>
          {% endif %}

        </div>
      {% endfor %}
    </div>

    <!-- Pagination dots (managed by Swiper, must be inside .swiper) -->
    {% if block.settings.show_pagination %}
      <div class="swiper-pagination"></div>
    {% endif %}
  </div>

  <!-- Navigation buttons — outside .swiper so CSS hover on .swiper-block works -->
  <button
    type="button"
    class="swiper-block__btn swiper-block__btn--prev"
    aria-label="{{ 'accessibility.slideshow_previous' | t }}"
  >
    <span class="svg-wrapper">{{- 'icon-chevron-left.svg' | inline_asset_content -}}</span>
  </button>

  <button
    type="button"
    class="swiper-block__btn swiper-block__btn--next"
    aria-label="{{ 'accessibility.slideshow_next' | t }}"
  >
    <span class="svg-wrapper">{{- 'icon-chevron-right.svg' | inline_asset_content -}}</span>
  </button>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
{% # theme-check-disable MissingAsset %}
<script src="{{ 'swiper-block.js' | asset_url }}" defer></script>
{% # theme-check-enable MissingAsset %}

