{% liquid
assign product = closest.product
  assign onboarding = false
  if product == blank or product.id == empty
    assign onboarding = true
  endif

  assign button_style = block.settings.button_style | default: 'outline'
  assign full_width   = block.settings.full_width   | default: true

assign btn_text_available = block.settings.button_text_available
  if btn_text_available == blank
    assign btn_text_available = 'Add to cart'
  endif

  assign btn_text_sold_out = block.settings.button_text_sold_out
  if btn_text_sold_out == blank
    assign btn_text_sold_out = 'Sold out'
  endif

  assign bg_color       = block.settings.background_color     | default: 'currentColor'
  assign text_color     = block.settings.text_color           | default: 'white'
  assign border_width   = block.settings.border_width         | default: 1
  assign border_radius  = block.settings.border_radius        | default: 4
  assign border_color   = block.settings.border_color         | default: 'currentColor'
  assign padding_top    = block.settings.padding_top          | default: 12
  assign padding_bottom = block.settings.padding_bottom       | default: 12
  assign padding_left   = block.settings.padding_left         | default: 20
  assign padding_right  = block.settings.padding_right        | default: 20
  assign font_size      = block.settings.font_size            | default: 14
  assign font_family    = block.settings.font_family          | default: 'inherit'
  assign hover_effect   = block.settings.hover_effect         | default: 'opacity'

  unless onboarding
    assign selected_variant = product.selected_or_first_available_variant
  endunless
%}

{% unless onboarding %}
  <div
    class="tabs-card-atc{% if full_width %} tabs-card-atc--full-width{% endif %}"
    {{ block.shopify_attributes }}
  >
    {% if product.available %}
      <button
        type="button"
        class="tabs-card-atc__btn tabs-card-atc__btn--{{ button_style }} tabs-card-atc__btn--hover-{{ hover_effect }}"
        data-variant-id="{{ selected_variant.id }}"
        aria-label="{{ btn_text_available }}: {{ product.title | escape }}"
        style="
          --atc-bg: {{ bg_color }};
          --atc-color: {{ text_color }};
          --atc-border-width: {{ border_width }}px;
          --atc-border-radius: {{ border_radius }}px;
          --atc-border-color: {{ border_color }};
          --atc-padding: {{ padding_top }}px {{ padding_right }}px {{ padding_bottom }}px {{ padding_left }}px;
          --atc-font-size: {{ font_size }}px;
          --atc-font-family: {{ font_family }};
        "
      >
        {{ btn_text_available }}
      </button>
    {% else %}
      <button
        type="button"
        class="tabs-card-atc__btn tabs-card-atc__btn--{{ button_style }} tabs-card-atc__btn--hover-{{ hover_effect }} tabs-card-atc__btn--disabled"
        disabled
        aria-disabled="true"
        style="
          --atc-bg: {{ bg_color }};
          --atc-color: {{ text_color }};
          --atc-border-width: {{ border_width }}px;
          --atc-border-radius: {{ border_radius }}px;
          --atc-border-color: {{ border_color }};
          --atc-padding: {{ padding_top }}px {{ padding_right }}px {{ padding_bottom }}px {{ padding_left }}px;
          --atc-font-size: {{ font_size }}px;
          --atc-font-family: {{ font_family }};
        "
      >
        {{ btn_text_sold_out }}
      </button>
    {% endif %}
  </div>
{% endunless %}

{% javascript %}
  (function () {
    /* ---- Toast helpers (singleton, injected once into <body>) ---- */
    var _hideTimer;

    function ensureToast() {
      var existing = document.getElementById('atc-toast');
      if (existing) return existing;

      var toast = document.createElement('div');
      toast.id = 'atc-toast';
      toast.className = 'atc-toast atc-toast--hidden';
      toast.setAttribute('role', 'status');
      toast.setAttribute('aria-live', 'polite');
      toast.innerHTML =
        '<div class="atc-toast__content">' +
          '<span class="atc-toast__check" aria-hidden="true">&#x2714;</span>' +
          '<div class="atc-toast__info">' +
            '<p class="atc-toast__title">Added to cart</p>' +
            '<p class="atc-toast__product"></p>' +
          '</div>' +
          '<button class="atc-toast__close" aria-label="Close notification">&#x00D7;</button>' +
        '</div>';

      document.body.appendChild(toast);

      toast.querySelector('.atc-toast__close').addEventListener('click', function () {
        hideToast();
      });

      return toast;
    }

    function showToast(productTitle) {
      var toast = ensureToast();
      var productEl = toast.querySelector('.atc-toast__product');
      productEl.textContent = productTitle || '';
      productEl.style.display = productTitle ? '' : 'none';
      toast.classList.remove('atc-toast--hidden');
      clearTimeout(_hideTimer);
      _hideTimer = setTimeout(hideToast, 4000);
    }

    function hideToast() {
      var toast = document.getElementById('atc-toast');
      if (toast) toast.classList.add('atc-toast--hidden');
    }

    /* ---- Cart count updater ---- */
    function refreshCartCount() {
      fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          /* Fire theme event for cart drawers etc. */
          document.dispatchEvent(new CustomEvent('cart:update', {
            bubbles: true,
            detail: { data: { itemCount: cart.item_count } }
          }));
          /* Update any visible count badge */
          document.querySelectorAll(
            '.cart-count, [data-cart-count], .header-custom__cart-count'
          ).forEach(function (el) {
            el.textContent = cart.item_count;
          });
        })
        .catch(function () {});
    }

    /* ---- Click handler (event delegation) ---- */
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.tabs-card-atc__btn');
      if (!btn || btn.disabled) return;
      e.preventDefault();

      /* Prefer variant selected by a variant-picker on the card, else use the rendered default */
      var card = btn.closest('[data-selected-variant]');
      var variantId = (card && card.dataset.selectedVariant) || btn.dataset.variantId;
      if (!variantId) return;

      var originalText = btn.textContent.trim();
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
      btn.textContent = '\u2026'; /* … */

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: Number(variantId), quantity: 1 })
      })
        .then(function (res) {
          if (!res.ok) {
            return res.json().then(function (body) {
              throw new Error(body.description || 'cart/add failed');
            });
          }
          return res.json();
        })
        .then(function (item) {
          refreshCartCount();
          showToast(item.product_title);
          btn.textContent = '\u2713'; /* ✓ */
          setTimeout(function () {
            btn.textContent = originalText;
            btn.disabled = false;
            btn.removeAttribute('aria-busy');
          }, 2000);
        })
        .catch(function (err) {
          console.error('[tabs-card-atc]', err);
          btn.textContent = 'Error';
          setTimeout(function () {
            btn.textContent = originalText;
            btn.disabled = false;
            btn.removeAttribute('aria-busy');
          }, 2000);
        });
    });
  })();
{% endjavascript %}

{% stylesheet %}
  .tabs-card-atc {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .tabs-card-atc--full-width .tabs-card-atc__btn {
    width: 100%;
  }

  .tabs-card-atc__btn {
    display: inline-block;
    padding: var(--atc-padding, 0.75rem 1.25rem);
    font-size: var(--atc-font-size, 0.875rem);
    font-family: var(--atc-font-family, inherit);
    font-weight: 500;
    line-height: 1;
    cursor: pointer;
    border: var(--atc-border-width, 1px) solid var(--atc-border-color, currentColor);
    border-radius: var(--atc-border-radius, 3px);
    background-color: var(--atc-bg, currentColor);
    color: var(--atc-color, white);
    letter-spacing: 0.03em;
    transition: all 0.2s ease;
  }

  /* Hover effects */
  .tabs-card-atc__btn--hover-opacity:hover {
    opacity: 0.85;
  }

  .tabs-card-atc__btn--hover-color-change:hover {
    background-color: color-mix(in srgb, var(--atc-bg) 70%, black);
    color: white;
  }

  .tabs-card-atc__btn--hover-scale:hover {
    transform: scale(1.05);
  }

  /* Disabled / loading state */
  .tabs-card-atc__btn--disabled,
  .tabs-card-atc__btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ================================================================
     ATC TOAST NOTIFICATION
     ================================================================ */
  .atc-toast {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
    width: 300px;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.14);
    padding: 14px 16px;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.28s ease, transform 0.28s ease, visibility 0.28s ease;
    visibility: visible;
  }

  .atc-toast--hidden {
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
    visibility: hidden;
  }

  .atc-toast__content {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .atc-toast__check {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: #1a1a1a;
    color: #fff;
    border-radius: 50%;
    font-size: 11px;
    line-height: 1;
    margin-top: 1px;
  }

  .atc-toast__info {
    flex: 1;
    min-width: 0;
  }

  .atc-toast__title {
    margin: 0;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #111;
    line-height: 1.4;
  }

  .atc-toast__product {
    margin: 2px 0 0;
    font-size: 0.75rem;
    color: #555;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .atc-toast__close {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: none;
    border: none;
    color: #888;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    border-radius: 4px;
    padding: 0;
    margin-top: -1px;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .atc-toast__close:hover {
    color: #111;
    background: rgba(0, 0, 0, 0.06);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Add to Cart",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style (base)",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "outline"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width button",
      "default": true
    },

    {
      "type": "header",
      "content": "Button Text"
    },
    {
      "type": "text",
      "id": "button_text_available",
      "label": "Text when available",
      "default": "Add to cart",
      "info": "Leave blank to use default translation"
    },
    {
      "type": "text",
      "id": "button_text_sold_out",
      "label": "Text when sold out",
      "default": "Sold out",
      "info": "Leave blank to use default translation"
    },

    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },

    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border thickness",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#000000"
    },

    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding left",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding right",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font family",
      "options": [
        { "value": "inherit", "label": "Inherit from theme" },
        { "value": "system-ui, sans-serif", "label": "System default" },
        { "value": "-apple-system, Roboto, sans-serif", "label": "Modern system" },
        { "value": "Georgia, serif", "label": "Serif (Georgia)" }
      ],
      "default": "inherit"
    },

    {
      "type": "header",
      "content": "Hover Effect"
    },
    {
      "type": "select",
      "id": "hover_effect",
      "label": "Hover effect",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "opacity", "label": "Fade (opacity)" },
        { "value": "color-change", "label": "Color change" },
        { "value": "scale", "label": "Scale up" }
      ],
      "default": "opacity"
    }
  ]
}
{% endschema %}