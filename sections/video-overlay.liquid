
<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    video-overlay-section
    color-{{ section.settings.color_scheme }}
  "
  style="
    --section-align: {{ section.settings.alignment }};
  "
  data-testid="video-overlay-section-{{ section.id }}"
>
  <div class="video-overlay-wrapper">

    {%- comment -%} Pass 1 — render video blocks as the base layer {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'video' -%}
        {%- assign bs = block.settings -%}

        {%- capture video_style -%}
          {%- render 'spacing-style', settings: bs -%}
          {%- render 'border-override', settings: bs -%}
          --size-style-width: {{ bs.custom_width }}%;
          --size-style-width-mobile: {{ bs.custom_width_mobile }}%;
          --size-style-aspect-ratio: {%- if bs.source == 'uploaded' -%}{{ bs.video.aspect_ratio | default: 'auto' }}{%- elsif bs.cover_image == blank -%}{{ bs.aspect_ratio }}{%- else -%}auto{%- endif -%};
        {%- endcapture -%}

        {%- if bs.source == 'uploaded' -%}
          {% render 'video',
            video: bs.video,
            video_class: 'size-style spacing-style border-style',
            video_loop: bs.video_loop,
            video_style: video_style,
            video_preview_image: bs.video.preview_image,
            additional_attributes: block.shopify_attributes,
            video_autoplay: bs.video_autoplay,
            disable_controls: false,
            show_controls: bs.show_controls,
            show_play_button: bs.show_play_button,
            show_mute_button: bs.show_mute_button,
            show_fullscreen_button: bs.show_fullscreen_button,
            show_progress_bar: bs.show_progress_bar,
            show_duration: bs.show_duration,
            controls_position: bs.controls_position,
            controls_layout: bs.controls_layout,
            flex_justify: bs.flex_justify,
            flex_align: bs.flex_align,
            flex_gap: bs.flex_gap,
            play_btn_position: bs.play_btn_position,
            play_padding_top: bs.play_padding_top,
            play_padding_right: bs.play_padding_right,
            play_padding_bottom: bs.play_padding_bottom,
            play_padding_left: bs.play_padding_left,
            mute_btn_position: bs.mute_btn_position,
            mute_padding_top: bs.mute_padding_top,
            mute_padding_right: bs.mute_padding_right,
            mute_padding_bottom: bs.mute_padding_bottom,
            mute_padding_left: bs.mute_padding_left,
            fs_btn_position: bs.fs_btn_position,
            fs_padding_top: bs.fs_padding_top,
            fs_padding_right: bs.fs_padding_right,
            fs_padding_bottom: bs.fs_padding_bottom,
            fs_padding_left: bs.fs_padding_left,
            dur_position: bs.dur_position,
            dur_padding_top: bs.dur_padding_top,
            dur_padding_right: bs.dur_padding_right,
            dur_padding_bottom: bs.dur_padding_bottom,
            dur_padding_left: bs.dur_padding_left,
            progress_position: bs.progress_position,
            progress_padding_top: bs.progress_padding_top,
            progress_padding_right: bs.progress_padding_right,
            progress_padding_bottom: bs.progress_padding_bottom,
            progress_padding_left: bs.progress_padding_left,
            section_id: section.id
          %}
        {%- else -%}
          {% render 'video',
            video_from_url: true,
            video: bs.video_url.id,
            video_class: 'size-style spacing-style border-style',
            video_type: bs.video_url.type,
            video_style: video_style,
            video_alt: bs.alt,
            video_preview_image: bs.cover_image,
            additional_attributes: block.shopify_attributes,
            disable_controls: false,
            show_controls: bs.show_controls,
            show_play_button: bs.show_play_button,
            show_mute_button: bs.show_mute_button,
            show_fullscreen_button: bs.show_fullscreen_button,
            show_progress_bar: bs.show_progress_bar,
            show_duration: bs.show_duration,
            controls_position: bs.controls_position,
            controls_layout: bs.controls_layout,
            flex_justify: bs.flex_justify,
            flex_align: bs.flex_align,
            flex_gap: bs.flex_gap,
            play_btn_position: bs.play_btn_position,
            play_padding_top: bs.play_padding_top,
            play_padding_right: bs.play_padding_right,
            play_padding_bottom: bs.play_padding_bottom,
            play_padding_left: bs.play_padding_left,
            mute_btn_position: bs.mute_btn_position,
            mute_padding_top: bs.mute_padding_top,
            mute_padding_right: bs.mute_padding_right,
            mute_padding_bottom: bs.mute_padding_bottom,
            mute_padding_left: bs.mute_padding_left,
            fs_btn_position: bs.fs_btn_position,
            fs_padding_top: bs.fs_padding_top,
            fs_padding_right: bs.fs_padding_right,
            fs_padding_bottom: bs.fs_padding_bottom,
            fs_padding_left: bs.fs_padding_left,
            dur_position: bs.dur_position,
            dur_padding_top: bs.dur_padding_top,
            dur_padding_right: bs.dur_padding_right,
            dur_padding_bottom: bs.dur_padding_bottom,
            dur_padding_left: bs.dur_padding_left,
            progress_position: bs.progress_position,
            progress_padding_top: bs.progress_padding_top,
            progress_padding_right: bs.progress_padding_right,
            progress_padding_bottom: bs.progress_padding_bottom,
            progress_padding_left: bs.progress_padding_left,
            section_id: section.id
          %}
        {%- endif -%}

      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Pass 2 — render overlay_button blocks on top {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'overlay_button' -%}
        {%- assign bs = block.settings -%}

        {%- if bs.is_overlay -%}
          {%- assign pos_class = 'overlay-btn-wrapper--' | append: bs.position -%}
          <div
            class="overlay-btn-wrapper {{ pos_class }}"
            style="
              --btn-offset-top: {{ bs.offset_top }}px;
              --btn-offset-right: {{ bs.offset_right }}px;
              --btn-offset-bottom: {{ bs.offset_bottom }}px;
              --btn-offset-left: {{ bs.offset_left }}px;
            "
            {{ block.shopify_attributes }}
          >
            {%- if bs.link != blank -%}
              <a
                class="overlay-btn button-extended{% if bs.hover_accent %} button-extended--accent{% endif %}"
                href="{{ bs.link }}"
                style="
                  --btn-bg: {{ bs.bg_color }};
                  --btn-text: {{ bs.text_color }};
                  --btn-border-width: {{ bs.border_width | default: 0 }}px;
                  --btn-border-radius: {{ bs.border_radius | default: 0 }}px;
                  --btn-border-color: {{ bs.border_color }};
                  --btn-pt: {{ bs.padding_top | default: 12 }}px;
                  --btn-pb: {{ bs.padding_bottom | default: 12 }}px;
                  --btn-pl: {{ bs.padding_left | default: 24 }}px;
                  --btn-pr: {{ bs.padding_right | default: 24 }}px;
                  --btn-font-size: {{ bs.font_size | default: 16 }}px;
                  --btn-font-family: {{ bs.font_family | default: 'inherit' }};
                "
                {%- if bs.open_in_new_tab %}
                  target="_blank"
                  rel="noopener noreferrer"
                {%- endif %}
              >
                {{- bs.label -}}
              </a>
            {%- else -%}
              <span
                class="overlay-btn button-extended{% if bs.hover_accent %} button-extended--accent{% endif %}"
                role="presentation"
                style="
                  --btn-bg: {{ bs.bg_color }};
                  --btn-text: {{ bs.text_color }};
                  --btn-border-width: {{ bs.border_width | default: 0 }}px;
                  --btn-border-radius: {{ bs.border_radius | default: 0 }}px;
                  --btn-border-color: {{ bs.border_color }};
                  --btn-pt: {{ bs.padding_top | default: 12 }}px;
                  --btn-pb: {{ bs.padding_bottom | default: 12 }}px;
                  --btn-pl: {{ bs.padding_left | default: 24 }}px;
                  --btn-pr: {{ bs.padding_right | default: 24 }}px;
                  --btn-font-size: {{ bs.font_size | default: 16 }}px;
                  --btn-font-family: {{ bs.font_family | default: 'inherit' }};
                "
              >{{- bs.label -}}</span>
            {%- endif -%}
          </div>

        {%- else -%}

          {%- comment -%} Inline (non-overlay) button — rendered in normal document flow below the video {%- endcomment -%}
          <div
            class="inline-btn-wrapper"
            style="
              --btn-align: {{ section.settings.alignment }};
            "
            {{ block.shopify_attributes }}
          >
            {%- if bs.link != blank -%}
              <a
                class="overlay-btn button-extended{% if bs.hover_accent %} button-extended--accent{% endif %}"
                href="{{ bs.link }}"
                style="
                  --btn-bg: {{ bs.bg_color }};
                  --btn-text: {{ bs.text_color }};
                  --btn-border-width: {{ bs.border_width | default: 0 }}px;
                  --btn-border-radius: {{ bs.border_radius | default: 0 }}px;
                  --btn-border-color: {{ bs.border_color }};
                  --btn-pt: {{ bs.padding_top | default: 12 }}px;
                  --btn-pb: {{ bs.padding_bottom | default: 12 }}px;
                  --btn-pl: {{ bs.padding_left | default: 24 }}px;
                  --btn-pr: {{ bs.padding_right | default: 24 }}px;
                  --btn-font-size: {{ bs.font_size | default: 16 }}px;
                  --btn-font-family: {{ bs.font_family | default: 'inherit' }};
                "
                {%- if bs.open_in_new_tab %}
                  target="_blank"
                  rel="noopener noreferrer"
                {%- endif %}
              >
                {{- bs.label -}}
              </a>
            {%- else -%}
              <span
                class="overlay-btn button-extended{% if bs.hover_accent %} button-extended--accent{% endif %}"
                role="presentation"
                style="
                  --btn-bg: {{ bs.bg_color }};
                  --btn-text: {{ bs.text_color }};
                  --btn-border-width: {{ bs.border_width | default: 0 }}px;
                  --btn-border-radius: {{ bs.border_radius | default: 0 }}px;
                  --btn-border-color: {{ bs.border_color }};
                  --btn-pt: {{ bs.padding_top | default: 12 }}px;
                  --btn-pb: {{ bs.padding_bottom | default: 12 }}px;
                  --btn-pl: {{ bs.padding_left | default: 24 }}px;
                  --btn-pr: {{ bs.padding_right | default: 24 }}px;
                  --btn-font-size: {{ bs.font_size | default: 16 }}px;
                  --btn-font-family: {{ bs.font_family | default: 'inherit' }};
                "
              >{{- bs.label -}}</span>
            {%- endif -%}
          </div>

        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

{% stylesheet %}
  /* ─── Section wrapper ─────────────────────────────────────────────────── */
  .video-overlay-section .section {
    display: flex;
    flex-direction: column;
    align-items: var(--section-align, flex-start);
  }

  /* ─── Relative container so absolute overlays anchor to the video ──────── */
  .video-overlay-wrapper {
    position: relative;
    width: 100%;
    display: block;
  }

  /* ─── Overlay button wrapper: invisible to pointer events so the video
         controls underneath remain fully interactive ────────────────────── */
  .overlay-btn-wrapper {
    position: absolute;
    z-index: 999; /* below custom video controls (z-index 10–11) */
    pointer-events: none; /* let clicks fall through to video layer */
    display: flex;
  }

  /* The actual <a> / <span> re-enables pointer events for itself only */
  .overlay-btn-wrapper > .overlay-btn {
    pointer-events: auto;
  }

  /* ─── Position presets ─────────────────────────────────────────────────── */
  .overlay-btn-wrapper--center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .overlay-btn-wrapper--top-left {
    top: var(--btn-offset-top, 16px);
    left: var(--btn-offset-left, 16px);
  }

  .overlay-btn-wrapper--top-right {
    top: var(--btn-offset-top, 16px);
    right: var(--btn-offset-right, 16px);
  }

  .overlay-btn-wrapper--bottom-left {
    bottom: var(--btn-offset-bottom, 16px);
    left: var(--btn-offset-left, 16px);
  }

  .overlay-btn-wrapper--bottom-right {
    bottom: var(--btn-offset-bottom, 16px);
    right: var(--btn-offset-right, 16px);
  }

  .overlay-btn-wrapper--top-center {
    top: var(--btn-offset-top, 16px);
    left: 50%;
    transform: translateX(-50%);
    width: auto;
    flex: 0 0 auto;
  }

  .overlay-btn-wrapper--bottom-center {
    bottom: var(--btn-offset-bottom, 16px);
    left: 50%;
    transform: translateX(-50%);
    width: auto;
    flex: 0 0 auto;
  }

  .overlay-btn-wrapper--left-center {
    left: var(--btn-offset-left, 16px);
    top: 50%;
    transform: translateY(-50%);
    width: auto;
    flex: 0 0 auto;
  }

  .overlay-btn-wrapper--right-center {
    right: var(--btn-offset-right, 16px);
    top: 50%;
    transform: translateY(-50%);
    width: auto;
    flex: 0 0 auto;
  }

  /* ─── Inline (non-overlay) button row ────────────────────────────────── */
  .inline-btn-wrapper {
    display: flex;
    justify-content: var(--btn-align, flex-start);
    width: 100%;
  }

  /* ─── The button element itself ────────────────────────────────────────── */
  .overlay-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s ease;
    /* appearance vars handled by .button-extended */
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Video With Overlay Button",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "source",
          "label": "Video source",
          "options": [
            {
              "value": "uploaded",
              "label": "Uploaded video"
            },
            {
              "value": "url",
              "label": "External URL (YouTube / Vimeo)"
            }
          ],
          "default": "uploaded"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "visible_if": "{{ block.settings.source == 'uploaded' }}"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Video URL",
          "accept": ["youtube", "vimeo"],
          "visible_if": "{{ block.settings.source == 'url' }}"
        },
        {
          "type": "checkbox",
          "id": "video_autoplay",
          "label": "Autoplay",
          "info": "Muted autoplay only; browser policies may override.",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "video_loop",
          "label": "Loop",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Cover image",
          "visible_if": "{{ block.settings.source == 'url' and block.settings.video_autoplay == false }}"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Video alt text",
          "visible_if": "{{ block.settings.source == 'url' }}"
        },
        {
          "type": "header",
          "content": "Size"
        },
        {
          "type": "range",
          "id": "custom_width",
          "label": "Width",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 100
        },
        {
          "type": "range",
          "id": "custom_width_mobile",
          "label": "Width (mobile)",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 100
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Aspect ratio",
          "options": [
            {
              "value": "auto",
              "label": "Auto"
            },
            {
              "value": "16/9",
              "label": "Landscape (16:9)"
            },
            {
              "value": "1/1",
              "label": "Square (1:1)"
            },
            {
              "value": "9/16",
              "label": "Portrait (9:16)"
            }
          ],
          "default": "16/9",
          "visible_if": "{{ block.settings.source == 'url' and block.settings.cover_image == blank }}"
        },
        {
          "type": "header",
          "content": "Borders"
        },
        {
          "type": "select",
          "id": "border",
          "label": "Style",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "solid", "label": "Solid" }
          ],
          "default": "none"
        },
        {
          "type": "range",
          "id": "border_width",
          "label": "Thickness",
          "min": 0, "max": 20, "step": 1, "unit": "px", "default": 1,
          "visible_if": "{{ block.settings.border != 'none' }}"
        },
        {
          "type": "range",
          "id": "border_opacity",
          "label": "Opacity",
          "min": 0, "max": 100, "step": 1, "unit": "%", "default": 100,
          "visible_if": "{{ block.settings.border != 'none' }}"
        },
        {
          "type": "range",
          "id": "border_radius",
          "label": "Border radius",
          "min": 0, "max": 40, "step": 1, "unit": "px", "default": 0
        },
        {
          "type": "header",
          "content": "Padding"
        },
        {
          "type": "range",
          "id": "padding-block-start",
          "label": "Top",
          "min": 0, "max": 32, "step": 1, "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "padding-block-end",
          "label": "Bottom",
          "min": 0, "max": 32, "step": 1, "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "padding-inline-start",
          "label": "Left",
          "min": 0, "max": 32, "step": 1, "unit": "px", "default": 0
        },
        {
          "type": "range",
          "id": "padding-inline-end",
          "label": "Right",
          "min": 0, "max": 32, "step": 1, "unit": "px", "default": 0
        },
        {
          "type": "header",
          "content": "Controls"
        },
        {
          "type": "checkbox",
          "id": "show_controls",
          "label": "Show native browser controls",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_play_button",
          "label": "Show play/pause button",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_mute_button",
          "label": "Show mute button",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_fullscreen_button",
          "label": "Show fullscreen button",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_progress_bar",
          "label": "Show progress bar",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_duration",
          "label": "Show duration",
          "default": false
        },
        {
          "type": "select",
          "id": "controls_position",
          "label": "Controls position",
          "options": [
            {
              "value": "bottom",
              "label": "Bottom"
            },
            {
              "value": "top",
              "label": "Top"
            },
            {
              "value": "center-overlay",
              "label": "Center overlay"
            },
            {
              "value": "outside",
              "label": "Outside (below)"
            }
          ],
          "default": "bottom"
        },
        {
          "type": "select",
          "id": "controls_layout",
          "label": "Controls layout",
          "options": [
            {
              "value": "horizontal",
              "label": "Horizontal"
            },
            {
              "value": "vertical",
              "label": "Vertical"
            }
          ],
          "default": "horizontal"
        },
        {
          "type": "header",
          "content": "Control Group Flex"
        },
        {
          "type": "select",
          "id": "flex_justify",
          "label": "Justify content",
          "options": [
            { "value": "flex-start", "label": "Start" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "End" },
            { "value": "space-between", "label": "Space between" },
            { "value": "space-around", "label": "Space around" }
          ],
          "default": "flex-start"
        },
        {
          "type": "select",
          "id": "flex_align",
          "label": "Align items",
          "options": [
            { "value": "flex-start", "label": "Start" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "End" },
            { "value": "stretch", "label": "Stretch" }
          ],
          "default": "center"
        },
        {
          "type": "range",
          "id": "flex_gap",
          "label": "Gap",
          "min": 0, "max": 32, "step": 1, "unit": "px", "default": 8
        },
        {
          "type": "header",
          "content": "Play Button — Position & Padding",
          "visible_if": "{{ block.settings.show_play_button == true }}"
        },
        {
          "type": "select",
          "id": "play_btn_position",
          "label": "Position",
          "options": [
            { "value": "inline", "label": "Inline (in control group)" },
            { "value": "top-left", "label": "Top left" },
            { "value": "top-right", "label": "Top right" },
            { "value": "bottom-left", "label": "Bottom left" },
            { "value": "bottom-right", "label": "Bottom right" }
          ],
          "default": "inline",
          "visible_if": "{{ block.settings.show_play_button == true }}"
        },
        { "type": "range", "id": "play_padding_top", "label": "Padding / offset top", "min": 0, "max": 64, "step": 1, "unit": "px", "default": 8, "visible_if": "{{ block.settings.show_play_button == true }}" },
        { "type": "range", "id": "play_padding_right", "label": "Padding / offset right", "min": 0, "max": 64, "step": 1, "unit": "px", "default": 8, "visible_if": "{{ block.settings.show_play_button == true }}" },
        { "type": "range", "id": "play_padding_bottom", "label": "Padding / offset bottom", "min": 0, "max": 64, "step": 1, "unit": "px", "default": 8, "visible_if": "{{ block.settings.show_play_button == true }}" },
        { "type": "range", "id": "play_padding_left", "label": "Padding / offset left", "min": 0, "max": 64, "step": 1, "unit": "px", "default": 8, "visible_if": "{{ block.settings.show_play_button == true }}" },
        {
