{% liquid
  assign product = closest.product
  assign onboarding = false
  if product == blank or product.id == empty
    assign onboarding = true
  endif

  assign card_padding = block.settings.card_padding | default: 0

  unless onboarding
    assign selected_variant = product.selected_or_first_available_variant
    assign is_sale = false
    if selected_variant.compare_at_price > selected_variant.price
      assign is_sale = true
    endif
  endunless
%}

<div
  class="collections-tabs-product-card"
  style="--card-padding: {{ card_padding }}px;"
  {% unless onboarding %}
    data-product-id="{{ product.id }}"
    data-selected-variant="{{ selected_variant.id }}"
  {% endunless %}
  {{ block.shopify_attributes }}
>
  {% content_for 'blocks' %}
</div>

{% stylesheet %}
  .collections-tabs-product-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
    padding: var(--card-padding, 0px);
  }

  /* ── Media ── */
  .ctpc-media {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: var(--ctpc-img-ratio, 3 / 4);
    background-color: #f5f5f5;
    flex-shrink: 0;
  }

  .ctpc-media img,
  .ctpc-media svg {
    width: 100%;
    height: 100%;
    object-fit: var(--ctpc-img-fit, cover);
    display: block;
  }

  .ctpc-media__link {
    display: block;
    height: 100%;
  }

  .ctpc-media--hover-zoom img:first-of-type {
    transition: transform 0.4s ease;
  }

  .ctpc-media--hover-zoom:hover img:first-of-type {
    transform: scale(1.06);
  }

  .ctpc-media__secondary {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: var(--ctpc-img-fit, cover);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .ctpc-media--hover-secondary:hover .ctpc-media__secondary { opacity: 1; }
  .ctpc-media--hover-secondary:hover img:first-of-type { opacity: 0; }

  /* ── Title ── */
  .ctpc-title--center { text-align: center; }
  .ctpc-title--right  { text-align: right; }

  .ctpc-title__text {
    margin: 0;
    font-size: var(--ctpc-title-size, 1rem);
    font-weight: var(--ctpc-title-weight, 500);
    color: var(--ctpc-title-color, inherit);
    line-height: 1.4;
  }

  .ctpc-title__link {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ctpc-title__link:hover { opacity: 0.7; }

  /* ── Price ── */
  .ctpc-price { font-size: 1rem; }
  .ctpc-price--center { text-align: center; }
  .ctpc-price--right  { text-align: right; }

  .ctpc-price__discount {
    display: inline-block;
    margin-left: 0.35em;
    font-size: 0.8em;
    font-weight: 600;
    color: var(--color-sale, #c0392b);
  }

  /* ── Description ── */
  .ctpc-description {
    font-size: 0.875rem;
    line-height: 1.5;
    opacity: 0.65;
  }

  .ctpc-description p { margin: 0; }

  /* ── Variants ── */
  .ctpc-variants { display: flex; flex-direction: column; gap: 0.35rem; }

  .ctpc-variants__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.55;
  }

  .ctpc-variants__select {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid currentColor;
    border-radius: 4px;
    font-size: 0.875rem;
    font-family: inherit;
    background-color: transparent;
    cursor: pointer;
  }

  .ctpc-variants__buttons { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  .ctpc-variant-btn {
    padding: 0.3rem 0.65rem;
    border: 1px solid currentColor;
    background: transparent;
    font-size: 0.8rem;
    font-family: inherit;
    cursor: pointer;
    border-radius: 3px;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .ctpc-variant-btn--active { background-color: currentColor; color: white; }
  .ctpc-variant-btn--unavailable { opacity: 0.4; cursor: not-allowed; text-decoration: line-through; }

  /* ── Add to Cart ── */
  .ctpc-atc { margin-top: auto; padding-top: 0.25rem; }
  .ctpc-atc--full .ctpc-atc__btn { width: 100%; }

  .ctpc-atc__btn {
    padding: 0.75rem 1.25rem;
    font-size: 0.875rem;
    font-family: inherit;
    font-weight: 500;
    cursor: pointer;
    border-radius: 3px;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    line-height: 1;
    letter-spacing: 0.03em;
  }

  .ctpc-atc__btn--primary {
    background-color: currentColor;
    color: white;
    border: 1px solid currentColor;
  }

  .ctpc-atc__btn--primary:not(:disabled):hover { opacity: 0.8; }

  .ctpc-atc__btn--secondary {
    background-color: transparent;
    color: currentColor;
    border: 1px solid transparent;
  }

  .ctpc-atc__btn--secondary:not(:disabled):hover { text-decoration: underline; }

  .ctpc-atc__btn--outline {
    background-color: transparent;
    color: currentColor;
    border: 1px solid currentColor;
  }

  .ctpc-atc__btn--outline:not(:disabled):hover {
    background-color: currentColor;
    color: white;
  }

  .ctpc-atc__btn:disabled { opacity: 0.45; cursor: not-allowed; }
{% endstylesheet %}

{% schema %}
{
  "name": "Tabs Product Card",
  "tag": null,
  "blocks": [
    { "type": "tabs-card-media" },
    { "type": "tabs-card-title" },
    { "type": "tabs-card-price" },
    { "type": "tabs-card-description" },
    { "type": "tabs-card-variants" },
    { "type": "tabs-card-atc" },
    { "type": "tabs-card-vendor" },
    { "type": "tabs-card-badge" }
  ],
  "settings": [
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
