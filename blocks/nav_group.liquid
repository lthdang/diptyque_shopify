
{%- liquid
  assign has_children = false
  if block.blocks.size > 0
    assign has_children = true
  endif
-%}

<li class="header-custom__item{% if has_children %} header-custom__item--has-dropdown{% endif %}" {{ block.shopify_attributes }}>
  {% if block.settings.link != blank and has_children == false %}
    <a class="header-custom__title" href="{{ block.settings.link }}">
      {{- block.settings.title -}}
    </a>
  {% else %}
    <button
      type="button"
      class="header-custom__title header-custom__title-button"
      aria-expanded="false"
      {% if has_children %}aria-controls="dropdown-{{ block.id }}"{% endif %}
    >
      <span class="header-custom__title-text">{{- block.settings.title -}}</span>
      {% if has_children %}
        <span class="header-custom__title-caret" aria-hidden="true">
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      {% endif %}
    </button>
  {% endif %}

  {% if has_children %}
    <div id="dropdown-{{ block.id }}" class="header-custom__dropdown" role="region" aria-label="{{ block.settings.title | escape }}">
      <div class="header-custom__dropdown-inner section section--full-width-margin section--{{ section.settings.section_width }}">
        <div class="header-custom__dropdown-grid">
          {% content_for 'blocks' %}
        </div>
      </div>
    </div>
  {% endif %}
</li>

{% schema %}
{
  "name": "Nav Group",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Navigation title",
      "default": "Menu item"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Optional link (used when no nested blocks are added)"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
